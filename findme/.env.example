# FindMe - Environment Configuration
# Copy this file to .env.local and fill in your values

# ─── Required ─────────────────────────────────────────
# Database URL (SQLite default, or PostgreSQL for production)
DATABASE_URL=file:./data/findme.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/findme

# NextAuth.js secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=change-me-to-a-random-string

# Public URL of your FindMe instance
NEXTAUTH_URL=http://localhost:3000

# JWT secret for mobile API tokens (generate with: openssl rand -base64 32)
JWT_SECRET=change-me-to-a-random-string

# Public URL for QR codes and mobile app connections
# For Docker: use your server's public IP/domain
# For Android emulator: use http://10.0.2.2:3000
FINDME_PUBLIC_URL=http://localhost:3000

# ─── Optional: Email Notifications (SMTP) ────────────
# Configure these to enable email notifications for invitations and geofence alerts
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=FindMe <your-email@gmail.com>
# SMTP_SECURE=false

# ─── Optional: WebAuthn/Passkeys ─────────────────────
# Only needed if using a non-localhost domain
# WEBAUTHN_RP_ID=your-domain.com
# WEBAUTHN_RP_NAME=FindMe
# WEBAUTHN_ORIGIN=https://your-domain.com
