+    fun getBestAvailableProvider(locationManager: LocationManager, accuracy: Int): String? {
+      val wantHighAccuracy = accuracy >= LocationModule.ACCURACY_HIGH
+      val criteria = Criteria().apply {
+        this.accuracy = if (wantHighAccuracy) Criteria.ACCURACY_FINE else Criteria.ACCURACY_COARSE
+        powerRequirement = if (wantHighAccuracy) Criteria.POWER_HIGH else Criteria.POWER_LOW
+      }
+      val best = locationManager.getBestProvider(criteria, true)
+      if (best != null) return best
+
+      // Fallback: try GPS first, then network
+      if (locationManager.isProviderEnabled(LocationManager.GPS_PROVIDER)) {
+        return LocationManager.GPS_PROVIDER
+      }
+      if (locationManager.isProviderEnabled(LocationManager.NETWORK_PROVIDER)) {
+        return LocationManager.NETWORK_PROVIDER
+      }
+      return null
+    }
+
